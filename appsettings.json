{
  "ConnectionStrings": {
    "Sqlite": "Data Source=data.db;Cache=Shared;"
  },

  "AppSettings": {
    "CredentialsFilePath":  "credentials.json",
    "SyncIntervalMinutes":  60,
    "SyncOnStartup":        true,
    "MaxSearchResults":     100,

    "Sheets": [
      {
        "SheetId":       "YOUR_PRODUCTS_SHEET_ID",
        "WorksheetName": "",
        "SheetType":     "Product",
        "DisplayName":   "Products"
      },
      {
        "SheetId":       "YOUR_CUSTOMERS_SHEET_ID",
        "WorksheetName": "Sheet1",
        "SheetType":     "Customer",
        "DisplayName":   "Customers"
      }
    ]
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":            "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System":               "Warning"
      }
    }
  },

  "AllowedHosts": "*"
}
